//@version=6
strategy(title = 'ifvg entry', overlay = true)

//user inputs
rr        = input.float(title = 'RR', defval = 1.5, step = 0.1)
fvgExtend = input.int(20, 'FVG zone extension')
showFVG   = input.bool(true, 'Show FVG zone')

// indicator
bullFVG = low > high[2]
bearFVG = high < low[2]

// storage
var float bullBottom = na
var float bullTop    = na

var float bearBottom = na
var float bearTop    = na

//capture fvg zones
if bullFVG
    bullBottom := high[2]
    bullTop    := low

if bearFVG
    bearTop    :=low[2]
    bearBottom := high

// plot FVG zones
if showFVG and bullFVG
    box.new(bar_index, bullTop, bar_index + fvgExtend, bullBottom, bgcolor = color.new(color.green, 85))

if showFVG and bearFVG
    box.new(bar_index, bearTop, bar_index + fvgExtend, bearBottom, bgcolor = color.new(color.red, 85))

// conditions
longCondition   = not na(bearTop) and close >= bearTop 
shortCondition  = not na(bullBottom) and close <= bullBottom 

// SL/TP
longSL  = bearBottom
longTP  = close + (close - bearBottom) * rr

shortSL = bullTop
shortTP = close - (shortSL - close) * rr

// entry/exit
if longCondition
    strategy.entry('LONG', strategy.long)
    strategy.exit('TP/SL Long', stop = longSL, limit = longTP)
if shortCondition
    strategy.entry('SHORT', strategy.short)
    strategy.exit('TP/SL Short', stop = shortSL, limit = shortTP)
